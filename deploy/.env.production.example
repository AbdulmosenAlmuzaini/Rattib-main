APP_DOMAIN=rattib.example.com

# Pin these images to tested immutable versions or digests before deployment.
POSTGRES_IMAGE=postgres:17-alpine
MINIO_IMAGE=minio/minio:latest
CADDY_IMAGE=caddy:2-alpine

POSTGRES_USER=rattib
POSTGRES_PASSWORD=replace-with-a-long-random-database-password
POSTGRES_DB=rattib
DATABASE_URL=postgresql://rattib:URL_ENCODED_PASSWORD@postgres:5432/rattib?schema=public

S3_REGION=us-east-1
S3_BUCKET=rattib-documents
S3_ACCESS_KEY=replace-with-a-random-storage-access-key
S3_SECRET_KEY=replace-with-a-long-random-storage-secret
S3_SERVER_SIDE_ENCRYPTION=

# First deployment only. Remove these values after the owner can sign in.
BOOTSTRAP_PRODUCTION=true
BOOTSTRAP_WORKSPACE_NAME=رتّب – مكتب المعقّب الذكي
BOOTSTRAP_WORKSPACE_SLUG=rattib-main
BOOTSTRAP_OWNER_NAME=مالك المكتب
BOOTSTRAP_OWNER_EMAIL=owner@example.com
SEED_ADMIN_PASSWORD=Replace-With-Unique-Password-2026!
