# Runtime
NODE_ENV="development"
PORT="3000"

# Local-only bootstrap password. Use a unique secret of at least 16 characters.
# Production must provision its first owner through a controlled deployment process.
SEED_ADMIN_PASSWORD="replace-with-a-long-random-password"

# PostgreSQL connection. Never commit production credentials.
DATABASE_URL="postgresql://rattib:rattib_local_dev_2026@127.0.0.1:54329/rattib?schema=public"

# Private S3-compatible document storage (MinIO locally).
S3_ENDPOINT="http://127.0.0.1:59000"
S3_REGION="us-east-1"
S3_BUCKET="rattib-documents"
S3_ACCESS_KEY="rattib_minio"
S3_SECRET_KEY="replace-with-a-long-random-secret"
S3_FORCE_PATH_STYLE="true"
# Set AES256 only when the production provider supports server-side encryption.
S3_SERVER_SIDE_ENCRYPTION=""
